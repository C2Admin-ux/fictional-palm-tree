# C2Admin environment variables.
# Copy to .env.local for local development and fill in real values.
# Never commit real values — .env.local is git-ignored.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — Supabase dashboard → Project Settings → API. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — Supabase dashboard → Project Settings → API. Safe to expose; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — Supabase dashboard → Project Settings → API. SERVER-ONLY: bypasses RLS, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ────────────────────────────────────────────────────────────────
# API key — console.anthropic.com → API Keys. SERVER-ONLY: used by lib/anthropic.ts for document OCR extraction (and the digest inbox scan).
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Resend ───────────────────────────────────────────────────────────────────
# API key — resend.com → API Keys. SERVER-ONLY: sends the weekly digest email and fetches inbound call-notes emails.
RESEND_API_KEY=re_your-key

# Inbound webhook signing secret — resend.com → Webhooks → the email.received endpoint pointing at /api/calls/inbound (starts with whsec_). SERVER-ONLY.
# When unset, the inbound route fails closed: only requests with ?token=<CRON_SECRET> are accepted (useful for local testing).
RESEND_INBOUND_SECRET=whsec_your-secret

# ── Cron / server-to-server auth ─────────────────────────────────────────────
# Shared secret for Bearer-authenticated route calls (Vercel Cron). Generate a long random string; set the same value in Vercel env vars. SERVER-ONLY.
CRON_SECRET=generate-a-long-random-string

# ── Optional ─────────────────────────────────────────────────────────────────
# Digest recipient — defaults to nick@c2cpllc.com if unset. SERVER-ONLY.
DIGEST_EMAIL=you@example.com

# Public base URL used for links in digest emails — defaults to the production Vercel URL if unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail MCP OAuth token for the digest inbox scan — currently unused (scan is disabled in app/api/digest/route.ts until a credential is provisioned). SERVER-ONLY.
GMAIL_MCP_AUTH_TOKEN=
